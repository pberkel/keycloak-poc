# Copy to secrets.yaml and fill in passwords before applying.
# secrets.yaml is gitignored — do not commit it.
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-pull-secret
  namespace: keycloak-poc
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: '{"auths":{"ghcr.io":{"username":"pberkel","password":"GITHUB_PAT"}}}'
---
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-admin
  namespace: keycloak-poc
type: Opaque
stringData:
  username: admin
  password: CHANGE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-db
  namespace: keycloak-poc
type: Opaque
stringData:
  username: keycloak
  password: CHANGE_ME
