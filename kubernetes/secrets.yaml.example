# Copy to secrets.yaml and fill in passwords before applying.
# secrets.yaml is gitignored — do not commit it.
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-admin
type: Opaque
stringData:
  username: admin
  password: CHANGE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-db
type: Opaque
stringData:
  username: keycloak
  password: CHANGE_ME
